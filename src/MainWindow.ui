<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="windowTitle">
   <string>医学影像分析平台</string>
  </property>
  <property name="styleSheet">
   <string notr="true">QMainWindow#MainWindow {
    background: #edf2f7;
}

QWidget#toolbarCard,
QWidget#listCard,
QWidget#infoCard,
QWidget#canvasCard {
    background: white;
    border: 1px solid #dbe3ee;
    border-radius: 12px;
}

QWidget#buttonRow1,
QWidget#buttonRow2,
QWidget#buttonRow3 {
    background: transparent;
}

QFrame#toolbarDivider {
    background: #e8eef5;
    min-height: 1px;
    max-height: 1px;
    border: none;
}

QPushButton {
    background: #f8fafc;
    color: #1e293b;
    border: 1px solid #dbe3ee;
    border-radius: 9px;
    padding: 8px 12px;
}

QPushButton:hover {
    background: #dbeafe;
}

QLabel#folderLabel,
QLabel#infoLabel,
QLabel#histogramLabel,
QLabel#previewHintLabel,
QLabel#filterLabel,
QLabel#listTitle,
QLabel#infoTitle,
QLabel#previewTitleLabel {
    color: #475569;
}

QLabel#filterLabel,
QLabel#listTitle,
QLabel#infoTitle,
QLabel#previewTitleLabel {
    color: #1e293b;
    font-weight: 700;
}

QLabel#zoomTextLabel {
    color: #64748b;
}

QLabel#zoomLabel {
    background: #eff6ff;
    color: #1d4ed8;
    border: 1px solid #bfdbfe;
    border-radius: 999px;
    padding: 4px 10px;
    font-weight: 700;
}

QLabel#histogramLabel {
    background: #f8fafc;
    color: #64748b;
    border: 1px solid #dbe3ee;
    border-radius: 10px;
    padding: 8px;
}

QComboBox {
    background: #f8fafc;
    color: #000000;
    border: 1px solid #dbe3ee;
    border-radius: 9px;
    padding: 6px 10px;
    min-width: 120px;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 24px;
    border: none;
}

QComboBox::down-arrow {
    image: none;
    width: 0px;
    height: 0px;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #64748b;
    margin-right: 8px;
}

QComboBox QAbstractItemView {
    color: #000000;
    background: #ffffff;
    selection-color: #000000;
    selection-background-color: #e0e0e0;
}

QListWidget {
    background: #f8fafc;
    color: #1e293b;
    border: none;
    border-radius: 10px;
    padding: 6px;
    font-family: Consolas;
}

QListWidget::item {
    padding: 6px 8px;
    border-radius: 6px;
}

QListWidget::item:selected {
    background: #bfdbfe;
    color: #0f172a;
}</string>
